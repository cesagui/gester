{
  "name": "jester",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch src/server.js",
    "dev:web": "npm --prefix gester-web-app run dev",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@hono/node-server": "^1.13.0",
    "dotenv": "^16.6.1",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
